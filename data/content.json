      "format": "story",
      "name": "The Shop for Chips!",
      "icon": "📖",
      "difficulty": 1,
      "ageRange": [4, 7],
      "focusSounds": ["sh", "ch", "th"],
      "pages": [
        {"text": "\"Let us go to <b>th</b>e <b>sh</b>op,\" says Mom.", "emoji": "🛒"},
        {"text": "I put on my <b>sh</b>oes. I <b>sh</b>ut <b>th</b>e door.", "emoji": "👟🚪"},
        {"text": "We walk on <b>th</b>e pa<b>th</b>. I see a <b>sh</b>ell!", "emoji": "🐚"},
        {"text": "At <b>th</b>e <b>sh</b>op, I pick <b>ch</b>ips and <b>ch</b>eese.", "emoji": "🍟🧀"},
        {"text": "Mom gets a bun<b>ch</b> of <b>ch</b>erries. Yum!", "emoji": "🍒"},
        {"text": "\"Can I have <b>ch</b>ocolate?\" I ask wi<b>th</b> a grin.", "emoji": "🍫😁"},
        {"text": "Mom says, \"<b>Sh</b>! Not too mu<b>ch</b>!\"", "emoji": "🤫"},
        {"text": "We pay and <b>th</b>ank <b>th</b>e man at <b>th</b>e till.", "emoji": "💰👋"},
        {"text": "Back home, I mun<b>ch</b> my <b>ch</b>ips on <b>th</b>e mat.", "emoji": "😋🏠"},
        {"text": "\"<b>Th</b>at was fun!\" I say. Mom gives me a big hug.", "emoji": "🤗💛"}
      ]
